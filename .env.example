# Copy to .env and fill in your Garmin Connect login.
# .env is gitignored - it is never committed.

GARMIN_EMAIL=you@example.com
GARMIN_PASSWORD=your-password

# Only if your account uses 2-factor auth. Put a FRESH code here right before
# running `garmin-sync auth` (an authenticator-app code works best). Leave blank otherwise.
GARMIN_MFA=
